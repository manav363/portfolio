# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real values.

# change 1: résumé PDF URL (hosted on Drive, Notion, or your deploy domain)
# Leave blank to fall back to #contact scroll
VITE_RESUME_URL=https://drive.google.com/file/d/YOUR_FILE_ID/view

# change 2: Formspree endpoint for in-page form submission (no mailto fallback needed)
# Sign up free at https://formspree.io → New Form → copy the endpoint
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID